# DatoCMS
DATOCMS_API_TOKEN=your_datocms_full_access_token_here
DATOCMS_WEBHOOK_SECRET=your_webhook_secret_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server
PORT=3000
NODE_ENV=production

# Locales supported (comma-separated, must match your DatoCMS locales)
LOCALES=pl-PL,en,ru

# Default locale (used as fallback)
DEFAULT_LOCALE=pl-PL

# Business context for SEO-optimized ALT texts
BUSINESS_CONTEXT=residential real estate developer specializing in premium apartments and housing estates
