{
  "name": "datocms-alt-generator",
  "version": "1.0.0",
  "description": "Automatic ALT text generation for DatoCMS media using Claude Vision API",
  "main": "src/server.js",
  "scripts": {
    "build:plugin": "esbuild datocms-plugin/src/index.js --bundle --outfile=datocms-plugin/public/bundle.js --format=iife --target=es2020",
    "prebuild": "npm run build:plugin",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "bulk": "node src/bulk-process.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@datocms/cma-client-node": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sharp": "^0.33.2",
    "datocms-plugin-sdk": "^2.1.1",
    "esbuild": "^0.27.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {},
  "dependencies_note": "esbuild and datocms-plugin-sdk in deps so Render installs them for build"
}
